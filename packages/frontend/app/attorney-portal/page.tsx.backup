"use client";

import { useState, FormEvent } from 'react';

interface Matter {
  id: number;
  name: string;
  amount: string;
  status: string;
  leakage: string;
  issues: number;
}

interface NavItem {
  id: string;
  label: string;
  icon: string;
}

interface NavGroup {
  label: string;
  items: NavItem[];
}

const QRCode = ({ value, size = 120 }: { value: string; size?: number }) => (
  <img 
    src={`https://api.qrserver.com/v1/create-qr-code/?size=${size}x${size}&data=${encodeURIComponent(value)}`} 
    alt="QR" 
    width={size} 
    height={size} 
    style={{ borderRadius: '0.5rem' }} 
  />
);

const MATTERS: Matter[] = [
  { id: 1, name: "Metro Boomin - Creepin' Dispute", amount: "$187,200", status: "Urgent", leakage: "31%", issues: 5 },
  { id: 2, name: "B.o.B Estate - 360 Deal Audit", amount: "$450,000", status: "In Progress", leakage: "22%", issues: 8 },
  { id: 3, name: "Future - Publishing Rights", amount: "$92,500", status: "Ready", leakage: "15%", issues: 3 },
];

const nav: NavGroup[] = [
  {
    label: "Matter Management",
    items: [
      { id: "dashboard", label: "Dashboard", icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" },
      { id: "new-matter", label: "New Matter", icon: "M12 4v16m8-8H4" }
    ]
  },
  {
    label: "Audit & Due Diligence",
    items: [
      { id: "digital-handshake", label: "Digital Handshake", icon: "M12 11c1.657 0 3-1.343 3-3S13.657 5 12 5 9 6.343 9 8s1.343 3 3 3zm0 2c-2.667 0-8 1.333-8 4v2h16v-2c0-2.667-5.333-4-8-4z" },
      { id: "run-due-diligence", label: "Run Catalog Due Diligence", icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" },
      { id: "pre-release-verify", label: "Pre-Release Split Verification", icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" }
    ]
  },
  {
    label: "Reports & Documents",
    items: [
      { id: "view-audit-report", label: "View Audit Report", icon: "M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" },
      { id: "generate-court-report", label: "Generate Court-Ready Report", icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" },
      { id: "generate-custom-report", label: "Generate Custom Report", icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" }
    ]
  },
  {
    label: "Legal Actions",
    items: [
      { id: "create-demand-letter", label: "Create Demand Letter", icon: "M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" },
      { id: "export-affidavit", label: "Export Affidavit", icon: "M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2" },
      { id: "export-hash-seal", label: "Export with Monad Hash Seal", icon: "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" }
    ]
  },
  {
    label: "Communication",
    items: [
      { id: "secure-message", label: "Secure Client Message", icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" }
    ]
  }
];

export default function AttorneyPortal() {
  const [activeSection, setActiveSection] = useState<string>('dashboard');
  const [selectedMatter, setSelectedMatter] = useState<number>(1);
  const [scanRunning, setScanRunning] = useState<boolean>(false);
  const [scanComplete, setScanComplete] = useState<boolean>(false);
  const [downloading, setDownloading] = useState<string | null>(null);
  const [handshakeTrack, setHandshakeTrack] = useState<string>('');
  const [handshakeEmail, setHandshakeEmail] = useState<string>('');
  const [handshakePercentage, setHandshakePercentage] = useState<string>('');
  const [message, setMessage] = useState<string>('');

  const matter = MATTERS.find(m => m.id === selectedMatter) || MATTERS[0];

  const runScan = (): void => {
    setScanRunning(true);
    setScanComplete(false);
    setTimeout(() => {
      setScanRunning(false);
      setScanComplete(true);
    }, 2500);
  };

  const handleHandshakeSubmit = async (e: FormEvent): Promise<void> => {
    e.preventDefault();
    
    try {
      const response = await fetch('http://localhost:8000/api/handshake/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          track_name: handshakeTrack,
          created_by: 'leron.rogers@foxrothschild.com',
          created_by_name: 'Leron Rogers',
          participants: [
            {
              name: 'Producer',
              email: handshakeEmail,
              percentage: parseInt(handshakePercentage),
              role: 'producer'
            }
          ]
        })
      });
      
      const data = await response.json();
      
      if (data.success) {
        alert(`✅ Digital Handshake sent! Magic links created for ${handshakeEmail}`);
        console.log('Handshake created:', data);
        
        // Clear the form
        setHandshakeTrack('');
        setHandshakeEmail('');
        setHandshakePercentage('');
      } else {
        alert('❌ Failed to create handshake');
      }
    } catch (error) {
      console.error('Error:', error);
      alert('❌ Error connecting to server');
    }
  };

  const handleSendMessage = (): void => {
    if (message.trim()) {
      alert(`Message sent: ${message}`);
      setMessage('');
    }
  };

  const showBar = !['dashboard', 'new-matter', 'secure-message', 'digital-handshake'].includes(activeSection);

  return (
    <div className="min-h-screen bg-gray-50">
      <div className="bg-gradient-to-r from-indigo-900 to-purple-900 text-white py-2 px-6 text-center text-sm font-medium">
        Attorney Portal - Secure Session | Encrypted and Hash-Verified
      </div>

      <header className="sticky top-0 z-50 bg-white border-b border-gray-200">
        <div className="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
          <div className="flex items-center space-x-4">
            <span className="text-2xl font-bold text-indigo-900">TrapRoyalties<span className="text-indigo-600">Pro</span></span>
            <span className="px-3 py-1 bg-indigo-100 text-indigo-800 text-sm rounded-full font-medium">Attorney Portal</span>
          </div>
          <div className="flex items-center space-x-6">
            <span className="text-sm text-gray-600">Leron Rogers (Fox Rothschild)</span>
            <button className="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm transition">Logout</button>
          </div>
        </div>
      </header>

      <div className="flex">
        <div className="w-72 bg-white border-r border-gray-200 min-h-screen p-6">
          <div className="space-y-8">
            {nav.map((group) => (
              <div key={group.label}>
                <p className="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">{group.label}</p>
                <div className="space-y-2">
                  {group.items.map((item) => (
                    <button
                      key={item.id}
                      onClick={() => setActiveSection(item.id)}
                      className={`w-full flex items-center space-x-3 p-3 rounded-lg transition ${
                        activeSection === item.id
                          ? 'bg-indigo-50 text-indigo-900 font-medium'
                          : 'text-gray-600 hover:bg-indigo-50'
                      }`}
                    >
                      <svg className="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d={item.icon} />
                      </svg>
                      <span>{item.label}</span>
                    </button>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div className="flex-1 p-8">
          {showBar && (
            <div className="mb-6 flex items-center gap-4 p-4 bg-indigo-50 rounded-lg border border-indigo-100">
              <span className="text-sm font-medium text-indigo-900 whitespace-nowrap">Active Matter:</span>
              <select
                value={selectedMatter}
                onChange={(e) => setSelectedMatter(Number(e.target.value))}
                className="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white text-black"
              >
                {MATTERS.map((m) => (
                  <option key={m.id} value={m.id}>{m.name}</option>
                ))}
              </select>
              <span className={`px-3 py-1 rounded-full text-xs font-bold ${
                matter.status === 'Urgent' ? 'bg-red-100 text-red-800' :
                matter.status === 'In Progress' ? 'bg-yellow-100 text-yellow-800' :
                'bg-green-100 text-green-800'
              }`}>
                {matter.status}
              </span>
            </div>
          )}

          {activeSection === 'dashboard' && (
            <div>
              <h1 className="text-4xl font-bold text-gray-900 mb-2">Welcome back, Leron</h1>
              <p className="text-gray-600 mb-8">Fox Rothschild LLP · Active Matters: 12</p>
              <div className="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
                <div className="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
                  <p className="text-sm text-gray-500 mb-1">Active Matters</p>
                  <p className="text-3xl font-bold text-gray-900">12</p>
                  <p className="text-xs text-green-600 mt-2">+3 this month</p>
                </div>
                <div className="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
                  <p className="text-sm text-gray-500 mb-1">Pending Audits</p>
                  <p className="text-3xl font-bold text-gray-900">8</p>
                  <p className="text-xs text-yellow-600 mt-2">4 require review</p>
                </div>
                <div className="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
                  <p className="text-sm text-gray-500 mb-1">Active Disputes</p>
                  <p className="text-3xl font-bold text-gray-900">3</p>
                  <p className="text-xs text-red-600 mt-2">2 urgent</p>
                </div>
                <div className="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
                  <p className="text-sm text-gray-500 mb-1">Black Box Value</p>
                  <p className="text-3xl font-bold text-green-600">$1.2M</p>
                  <p className="text-xs text-indigo-600 mt-2">Unclaimed royalties</p>
                </div>
              </div>

              <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                <h2 className="text-2xl font-bold text-gray-900 mb-6">Recent Matters</h2>
                <div className="space-y-4">
                  {MATTERS.map((m) => (
                    <div key={m.id} className="flex items-center justify-between p-4 bg-gray-50 rounded-xl">
                      <div>
                        <p className="font-bold text-lg text-gray-900">{m.name}</p>
                        <p className="text-sm text-gray-500">{m.amount} · {m.issues} issues flagged</p>
                      </div>
                      <span className={`px-3 py-1 rounded-full text-sm font-medium ${
                        m.status === 'Urgent' ? 'bg-red-100 text-red-800' :
                        m.status === 'In Progress' ? 'bg-yellow-100 text-yellow-800' :
                        'bg-green-100 text-green-800'
                      }`}>
                        {m.status}
                      </span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}

          {activeSection === 'digital-handshake' && (
            <div>
              <h1 className="text-3xl font-bold text-gray-900 mb-2">Digital Handshake</h1>
              <p className="text-gray-600 mb-6">Create legally binding split agreements instantly</p>
              <div className="grid md:grid-cols-2 gap-8">
                <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
                  <h3 className="text-xl font-bold mb-6">Create New Split Agreement</h3>
                  <form onSubmit={handleHandshakeSubmit} className="space-y-4">
                    <input 
                      type="text" 
                      value={handshakeTrack} 
                      onChange={(e) => setHandshakeTrack(e.target.value)} 
                      placeholder="Track / Project" 
                      className="w-full px-4 py-3 border rounded-lg text-black bg-white" 
                      required 
                    />
                    <input 
                      type="email" 
                      value={handshakeEmail} 
                      onChange={(e) => setHandshakeEmail(e.target.value)} 
                      placeholder="Producer/Writer Email" 
                      className="w-full px-4 py-3 border rounded-lg text-black bg-white" 
                      required 
                    />
                    <input 
                      type="number" 
                      value={handshakePercentage} 
                      onChange={(e) => setHandshakePercentage(e.target.value)} 
                      placeholder="Percentage" 
                      className="w-full px-4 py-3 border rounded-lg text-black bg-white" 
                      required 
                    />
                    <button type="submit" className="w-full py-4 bg-indigo-900 text-white rounded-lg">
                      Send Digital Handshake
                    </button>
                  </form>
                </div>
                <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
                  <h3 className="text-xl font-bold mb-6">Recent Invites</h3>
                  <div className="space-y-3">
                    <div className="p-4 bg-gray-50 rounded-lg border">
                      <p className="font-medium">Neon Dreams</p>
                      <p className="text-sm text-gray-500">Sent to producer@email.com · 50%</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {activeSection === 'run-due-diligence' && (
            <div>
              <h1 className="text-3xl font-bold text-gray-900 mb-2">Run Catalog Due Diligence</h1>
              <p className="text-gray-600 mb-6">Perform forensic audit for: <span className="font-bold">{matter.name}</span></p>
              <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
                <div className="mb-8">
                  <h2 className="text-lg font-semibold mb-4">Select Client / Matter</h2>
                  <select 
                    value={selectedMatter} 
                    onChange={(e) => setSelectedMatter(Number(e.target.value))} 
                    className="w-full px-4 py-3 border rounded-lg text-black bg-white"
                  >
                    {MATTERS.map(m => <option key={m.id} value={m.id}>{m.name}</option>)}
                  </select>
                </div>
                <div className="mb-8">
                  <h2 className="text-lg font-semibold mb-4">Upload Catalog</h2>
                  <div className="border-2 border-dashed border-gray-300 rounded-xl p-8 text-center">
                    <p className="text-gray-600">Drag and drop files here</p>
                  </div>
                </div>
                <button onClick={runScan} className="w-full py-4 bg-indigo-900 text-white rounded-lg">Start Scan</button>
              </div>
            </div>
          )}

          {activeSection === 'secure-message' && (
            <div>
              <h1 className="text-3xl font-bold text-gray-900 mb-2">Secure Client Message</h1>
              <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-6 h-[500px] flex flex-col">
                <div className="flex-1 overflow-y-auto mb-4">
                  <div className="flex justify-end mb-4">
                    <div className="bg-indigo-900 text-white p-3 rounded-lg max-w-md">Ready to send demand letter?</div>
                  </div>
                  <div className="flex justify-start mb-4">
                    <div className="bg-gray-100 p-3 rounded-lg max-w-md">Let's move forward.</div>
                  </div>
                </div>
                <div className="flex gap-2">
                  <input 
                    type="text" 
                    value={message} 
                    onChange={(e) => setMessage(e.target.value)} 
                    placeholder="Type message..." 
                    className="flex-1 px-4 py-2 border rounded-lg text-black bg-white" 
                  />
                  <button 
                    onClick={handleSendMessage} 
                    className="px-6 py-2 bg-indigo-900 text-white rounded-lg"
                  >
                    Send
                  </button>
                </div>
              </div>
            </div>
          )}

          {activeSection === 'new-matter' && (
            <div>
              <h1 className="text-3xl font-bold text-gray-900 mb-2">Create New Matter</h1>
              <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-8 max-w-3xl">
                <form className="space-y-4">
                  <input 
                    type="text" 
                    placeholder="Client Name" 
                    className="w-full px-4 py-3 border rounded-lg text-black bg-white" 
                  />
                  <input 
                    type="text" 
                    placeholder="Project Name" 
                    className="w-full px-4 py-3 border rounded-lg text-black bg-white" 
                  />
                  <button type="submit" className="w-full py-4 bg-indigo-900 text-white rounded-lg">
                    Create Matter
                  </button>
                </form>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
